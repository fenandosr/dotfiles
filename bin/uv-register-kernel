#!/usr/bin/env bash
set -euo pipefail

PROJECT_DIR="${1:-$(pwd)}"
PROJECT_DIR="$(cd "$PROJECT_DIR" && pwd)"

if [[ ! -f "$PROJECT_DIR/pyproject.toml" ]]; then
  echo "Error: no encontré pyproject.toml en $PROJECT_DIR" >&2
  exit 1
fi

NAME="${2:-$(basename "$PROJECT_DIR")}"
DISPLAY_NAME="${3:-Python ($NAME)}"

cd "$PROJECT_DIR"

# Asegura que exista .venv
uv sync

# Asegura ipykernel como dev dependency
if ! grep -q 'ipykernel' pyproject.toml; then
  uv add --dev ipykernel
fi

uv run ipython kernel install \
  --user \
  --env VIRTUAL_ENV "$PROJECT_DIR/.venv" \
  --name "$NAME" \
  --display-name "$DISPLAY_NAME"

echo "Kernel registrado:"
echo "  name         = $NAME"
echo "  display-name = $DISPLAY_NAME"
echo "  project      = $PROJECT_DIR"
