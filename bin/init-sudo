## ~/bin/init-sudo
#!/usr/bin/env bash
## add file /etc/sudoers.d/[file]
[[ "$OSTYPE" == darwin* ]] && { echo "Not needed on macOS (use System Settings > sudo)"; exit 0; }
echo "$USER ALL=(ALL) NOPASSWD: ALL" | sudo tee /etc/sudoers.d/$USER-nopasswd
sudo chmod 440 /etc/sudoers.d/$USER-nopasswd
sudo visudo -c
