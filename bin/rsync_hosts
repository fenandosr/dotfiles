#!/usr/bin/env bash
set -Eeuo pipefail

readonly PROGRAM="${0##*/}"
readonly CONFIG_FILE="${RSYNC_HOSTS_CONFIG:-${HOME}/bin/.rsync_hosts}"

MODE="push"
DRY_RUN=0
DELETE_REMOTE=0
VERBOSE=0
OVERWRITE_NEWER=0
LIST_HOSTS=0
SOURCE_DIR=""
RUN_ID="$(date -u +%Y%m%dT%H%M%SZ)-$$"

declare -a REQUESTED_HOSTS=()
declare -a TARGET_HOSTS=()
declare -a ALL_HOSTS=()

usage() {
    cat <<EOF_USAGE
Usage:
  ${PROGRAM} [options] DIRECTORY

Modes:
      --push                 Push local DIRECTORY to the hosts (default)
  -c, --collect              Pull each file's newest version from the hosts
                             into local DIRECTORY

Host selection:
  -H, --host NAME            Use only NAME; may be repeated
      --hosts A,B,C          Use only the comma-separated host list
      --list-hosts           List configured hosts and exit

Safety:
  -n, --dry-run              Show changes without modifying files
  -d, --delete               Push mode only: delete remote files absent locally
      --overwrite-newer      Push mode only: overwrite newer remote files

Output:
  -v, --verbose              More rsync output and statistics
  -h, --help                 Show this help

Collector rules:
  * Local DIRECTORY also participates as a candidate.
  * The version with the greatest mtime wins for each relative path.
  * Checksums distinguish equal content from a real content conflict.
  * Same content: retain the greatest mtime, without a content backup.
  * Different content: back up the local version before replacing it.
  * Missing files are never deleted locally.

Examples:
  ${PROGRAM} ~/repos/iris-lib
  ${PROGRAM} --host hpc01 ~/repos/iris-lib
  ${PROGRAM} --collect ~/repos/iris-lib
  ${PROGRAM} --collect --host hpc01 ~/repos/iris-lib
  ${PROGRAM} --collect --hosts hpc01,hpc02 ~/repos/iris-lib
  ${PROGRAM} --collect --dry-run ~/repos/iris-lib

Configuration:
  ${CONFIG_FILE}
EOF_USAGE
}

log() {
    printf '[%s] %s\n' "${PROGRAM}" "$*" >&2
}

warn() {
    printf '[%s] WARNING: %s\n' "${PROGRAM}" "$*" >&2
}

die() {
    printf '[%s] ERROR: %s\n' "${PROGRAM}" "$*" >&2
    exit 1
}

require_command() {
    command -v "$1" >/dev/null 2>&1 || die "Required command not found: $1"
}

trim() {
    local value="$1"
    value="${value#"${value%%[![:space:]]*}"}"
    value="${value%"${value##*[![:space:]]}"}"
    printf '%s' "${value}"
}

add_host() {
    local name
    name="$(trim "$1")"
    [[ -n "${name}" ]] || die "Empty host name"
    REQUESTED_HOSTS+=("${name}")
}

add_host_list() {
    local value="$1"
    local -a names=()
    local name

    IFS=',' read -r -a names <<< "${value}"

    for name in "${names[@]}"; do
        add_host "${name}"
    done
}

parse_arguments() {
    while (($# > 0)); do
        case "$1" in
            --push)
                MODE="push"
                shift
                ;;
            -c|--collect)
                MODE="collect"
                shift
                ;;
            -H|--host)
                (($# >= 2)) || die "$1 requires a host name"
                add_host "$2"
                shift 2
                ;;
            --host=*)
                add_host "${1#*=}"
                shift
                ;;
            --hosts)
                (($# >= 2)) || die "$1 requires a comma-separated list"
                add_host_list "$2"
                shift 2
                ;;
            --hosts=*)
                add_host_list "${1#*=}"
                shift
                ;;
            --list-hosts)
                LIST_HOSTS=1
                shift
                ;;
            -n|--dry-run)
                DRY_RUN=1
                shift
                ;;
            -d|--delete)
                DELETE_REMOTE=1
                shift
                ;;
            --overwrite-newer)
                OVERWRITE_NEWER=1
                shift
                ;;
            -v|--verbose)
                VERBOSE=1
                shift
                ;;
            -h|--help)
                usage
                exit 0
                ;;
            --)
                shift
                (($# == 1)) || die "Exactly one directory is required after --"
                SOURCE_DIR="$1"
                shift
                ;;
            -*)
                die "Unknown option: $1"
                ;;
            *)
                [[ -z "${SOURCE_DIR}" ]] || die "Only one directory is allowed"
                SOURCE_DIR="$1"
                shift
                ;;
        esac
    done
}

set_config_defaults() {
    declare -p RSYNC_HOSTS >/dev/null 2>&1 || die "RSYNC_HOSTS is not defined in ${CONFIG_FILE}"
    [[ "$(declare -p RSYNC_HOSTS 2>/dev/null)" == "declare -A"* ]] || die "RSYNC_HOSTS must be an associative Bash array"

    : "${RSYNC_USER:=$(id -un)}"
    : "${RSYNC_SSH_PORT:=22}"
    : "${RSYNC_REMOTE_ROOT:=}"
    : "${RSYNC_REMOTE_BACKUP_ROOT:=}"
    : "${RSYNC_LOCAL_BACKUP_ROOT:=}"
    : "${RSYNC_COMPRESS_LEVEL:=6}"
    : "${RSYNC_TIMEOUT_SECONDS:=300}"
    : "${RSYNC_PRESERVE_ACL_XATTR:=0}"
    : "${RSYNC_PRESERVE_OWNER_GROUP:=0}"
    : "${RSYNC_COLLECT_CHECKSUM:=1}"
    : "${RSYNC_PUSH_CHECKSUM:=1}"

    if ! declare -p RSYNC_SSH_OPTIONS >/dev/null 2>&1; then
        RSYNC_SSH_OPTIONS=()
    fi

    if ! declare -p RSYNC_EXCLUDES >/dev/null 2>&1; then
        RSYNC_EXCLUDES=()
    fi
}

validate_config() {
    local name

    ((${#RSYNC_HOSTS[@]} > 0)) || die "RSYNC_HOSTS is empty in ${CONFIG_FILE}"

    for name in "${!RSYNC_HOSTS[@]}"; do
        [[ "${name}" =~ ^[A-Za-z0-9._-]+$ ]] || die "Invalid host name: ${name}"
        [[ -n "${RSYNC_HOSTS[$name]}" ]] || die "Host ${name} has an empty address"
    done

    [[ "${RSYNC_SSH_PORT}" =~ ^[0-9]+$ ]] || die "RSYNC_SSH_PORT must be numeric"
    [[ "${RSYNC_COMPRESS_LEVEL}" =~ ^[0-9]$ ]] || die "RSYNC_COMPRESS_LEVEL must be between 0 and 9"
    [[ "${RSYNC_TIMEOUT_SECONDS}" =~ ^[0-9]+$ ]] || die "RSYNC_TIMEOUT_SECONDS must be numeric"

    case "${RSYNC_PRESERVE_ACL_XATTR}" in 0|1) ;; *) die "RSYNC_PRESERVE_ACL_XATTR must be 0 or 1" ;; esac
    case "${RSYNC_PRESERVE_OWNER_GROUP}" in 0|1) ;; *) die "RSYNC_PRESERVE_OWNER_GROUP must be 0 or 1" ;; esac
    case "${RSYNC_COLLECT_CHECKSUM}" in 0|1) ;; *) die "RSYNC_COLLECT_CHECKSUM must be 0 or 1" ;; esac
    case "${RSYNC_PUSH_CHECKSUM}" in 0|1) ;; *) die "RSYNC_PUSH_CHECKSUM must be 0 or 1" ;; esac

    if [[ "${MODE}" == "collect" && "${DELETE_REMOTE}" == "1" ]]; then
        die "--delete is not allowed in collector mode"
    fi

    if [[ "${MODE}" == "collect" && "${OVERWRITE_NEWER}" == "1" ]]; then
        die "--overwrite-newer is not allowed in collector mode"
    fi
}

list_hosts() {
    local name

    printf '%-24s %s\n' "NAME" "ADDRESS"

    while IFS= read -r name; do
        printf '%-24s %s\n' "${name}" "${RSYNC_HOSTS[$name]}"
    done < <(printf '%s\n' "${!RSYNC_HOSTS[@]}" | LC_ALL=C sort)
}

select_hosts() {
    local name
    local available
    local -a invalid=()
    declare -A seen=()

    mapfile -t ALL_HOSTS < <(printf '%s\n' "${!RSYNC_HOSTS[@]}" | LC_ALL=C sort)

    if ((${#REQUESTED_HOSTS[@]} == 0)); then
        TARGET_HOSTS=("${ALL_HOSTS[@]}")
        return
    fi

    for name in "${REQUESTED_HOSTS[@]}"; do
        if [[ ! "${name}" =~ ^[A-Za-z0-9._-]+$ || -z "${RSYNC_HOSTS[$name]+exists}" ]]; then
            invalid+=("${name}")
            continue
        fi

        if [[ -z "${seen[$name]+selected}" ]]; then
            TARGET_HOSTS+=("${name}")
            seen["${name}"]=1
        fi
    done

    if ((${#invalid[@]} > 0)); then
        printf -v available '%s, ' "${ALL_HOSTS[@]}"
        available="${available%, }"
        die "Unknown host(s): ${invalid[*]}. Valid hosts: ${available}"
    fi
}

build_ssh_transport() {
    SSH_COMMAND=(ssh -T -p "${RSYNC_SSH_PORT}")
    SSH_COMMAND+=("${RSYNC_SSH_OPTIONS[@]}")

    printf -v RSYNC_RSH '%q ' "${SSH_COMMAND[@]}"
    RSYNC_RSH="${RSYNC_RSH% }"
}

resolve_remote_directory() {
    if [[ -z "${RSYNC_REMOTE_ROOT}" ]]; then
        REMOTE_DIR="${SOURCE_DIR}"
    else
        REMOTE_DIR="${RSYNC_REMOTE_ROOT%/}/$(basename -- "${SOURCE_DIR}")"
    fi
}

remote_login_for() {
    local name="$1"
    local address="${RSYNC_HOSTS[$name]}"

    if [[ "${address}" == *@* ]]; then
        printf '%s\n' "${address}"
    else
        printf '%s@%s\n' "${RSYNC_USER}" "${address}"
    fi
}

remote_backup_dir_for() {
    local name="$1"

    if [[ -z "${RSYNC_REMOTE_BACKUP_ROOT}" ]]; then
        printf '%s/%s/%s\n' "${REMOTE_DIR}.rsync-backups" "${RUN_ID}" "${name}"
    else
        printf '%s/%s/%s/%s\n' "${RSYNC_REMOTE_BACKUP_ROOT%/}" "$(basename -- "${SOURCE_DIR}")" "${RUN_ID}" "${name}"
    fi
}

local_backup_dir_for() {
    local name="$1"

    if [[ -z "${RSYNC_LOCAL_BACKUP_ROOT}" ]]; then
        printf '%s/%s/%s\n' "${SOURCE_DIR}.rsync-collector-backups" "${RUN_ID}" "${name}"
    else
        printf '%s/%s/%s/%s\n' "${RSYNC_LOCAL_BACKUP_ROOT%/}" "$(basename -- "${SOURCE_DIR}")" "${RUN_ID}" "${name}"
    fi
}

build_common_options() {
    local -n output="$1"
    local exclude

    output=(
        --archive
        --hard-links
        --partial
        --partial-dir=.rsync-partial
        --human-readable
        --itemize-changes
        --protect-args
        --compress
        --compress-level="${RSYNC_COMPRESS_LEVEL}"
        --timeout="${RSYNC_TIMEOUT_SECONDS}"
        --rsh="${RSYNC_RSH}"
    )

    if [[ "${RSYNC_PRESERVE_OWNER_GROUP}" != "1" ]]; then
        output+=(--no-owner --no-group)
    fi

    if [[ "${RSYNC_PRESERVE_ACL_XATTR}" == "1" ]]; then
        output+=(--acls --xattrs)
    fi

    if [[ "${VERBOSE}" == "1" ]]; then
        output+=(--verbose --stats)
    fi

    for exclude in "${RSYNC_EXCLUDES[@]}"; do
        output+=(--exclude="${exclude}")
    done
}

push_to_host() {
    local name="$1"
    local remote_login
    local backup_dir
    local remote_command
    local -a options=()

    remote_login="$(remote_login_for "${name}")"
    backup_dir="$(remote_backup_dir_for "${name}")"

    log "Host: ${name}"
    log "Push destination: ${remote_login}:${REMOTE_DIR}/"
    log "Remote backup: ${remote_login}:${backup_dir}/"

    if [[ "${DRY_RUN}" != "1" ]]; then
        printf -v remote_command 'mkdir -p -- %q %q' "${REMOTE_DIR}" "${backup_dir}"
        "${SSH_COMMAND[@]}" "${remote_login}" "${remote_command}" || return 1
    fi

    build_common_options options
    options+=(--backup --backup-dir="${backup_dir}")

    if [[ "${OVERWRITE_NEWER}" != "1" ]]; then
        options+=(--update)
    fi

    if [[ "${RSYNC_PUSH_CHECKSUM}" == "1" ]]; then
        options+=(--checksum)
    fi

    if [[ "${DELETE_REMOTE}" == "1" ]]; then
        options+=(--delete --delete-delay)
    fi

    if [[ "${DRY_RUN}" == "1" ]]; then
        options+=(--dry-run)
    fi

    rsync "${options[@]}" "${SOURCE_DIR}/" "${remote_login}:${REMOTE_DIR}/" || return 1

    if [[ "${DRY_RUN}" != "1" ]]; then
        printf -v remote_command 'rmdir -- %q 2>/dev/null || true' "${backup_dir}"
        "${SSH_COMMAND[@]}" "${remote_login}" "${remote_command}" >/dev/null 2>&1 || true
    fi
}

collect_from_host() {
    local name="$1"
    local remote_login
    local backup_dir
    local remote_command
    local -a options=()

    remote_login="$(remote_login_for "${name}")"
    backup_dir="$(local_backup_dir_for "${name}")"

    log "Host: ${name}"
    log "Collect source: ${remote_login}:${REMOTE_DIR}/"
    log "Local destination: ${SOURCE_DIR}/"
    log "Local backup: ${backup_dir}/"

    printf -v remote_command 'test -d %q' "${REMOTE_DIR}"

    if ! "${SSH_COMMAND[@]}" "${remote_login}" "${remote_command}"; then
        warn "Remote directory is missing or inaccessible on ${name}: ${REMOTE_DIR}"
        return 1
    fi

    if [[ "${DRY_RUN}" != "1" ]]; then
        mkdir -p -- "${backup_dir}"
    fi

    build_common_options options
    options+=(--update --backup --backup-dir="${backup_dir}" --omit-dir-times)

    if [[ "${RSYNC_COLLECT_CHECKSUM}" == "1" ]]; then
        options+=(--checksum)
    fi

    if [[ "${DRY_RUN}" == "1" ]]; then
        options+=(--dry-run)
    fi

    rsync "${options[@]}" "${remote_login}:${REMOTE_DIR}/" "${SOURCE_DIR}/" || return 1

    if [[ "${DRY_RUN}" != "1" ]]; then
        rmdir -- "${backup_dir}" 2>/dev/null || true
    fi
}

run() {
    local name
    local successes=0
    local failures=0

    validate_config

    if [[ "${LIST_HOSTS}" == "1" ]]; then
        list_hosts
        exit 0
    fi

    [[ -n "${SOURCE_DIR}" ]] || die "A directory is required"
    [[ -d "${SOURCE_DIR}" ]] || die "Directory not found: ${SOURCE_DIR}"

    require_command rsync
    require_command ssh
    require_command realpath

    SOURCE_DIR="$(realpath -- "${SOURCE_DIR}")"
    [[ "${SOURCE_DIR}" != "/" ]] || die "Refusing to synchronize /"

    select_hosts
    build_ssh_transport
    resolve_remote_directory

    log "Mode: ${MODE}"
    log "Local directory: ${SOURCE_DIR}"
    log "Remote directory: ${REMOTE_DIR}"
    log "Targets: ${TARGET_HOSTS[*]}"
    log "Run ID: ${RUN_ID}"

    if [[ "${MODE}" == "push" && "${RSYNC_PUSH_CHECKSUM}" == "1" ]]; then
        log "Push comparison: exact content checksum"
    fi

    if [[ "${MODE}" == "collect" ]]; then
        if [[ "${RSYNC_COLLECT_CHECKSUM}" == "1" ]]; then
            log "Collector comparison: exact content checksum"
        else
            warn "Collector comparison uses only rsync's size/mtime quick check"
        fi

        log "Host processing order: ${TARGET_HOSTS[*]}"
        log "On an exact mtime tie with different content, the later processed host wins and the previous version is backed up"
    fi

    for name in "${TARGET_HOSTS[@]}"; do
        printf '\n' >&2

        if [[ "${MODE}" == "collect" ]]; then
            if collect_from_host "${name}"; then
                successes=$((successes + 1))
                log "Collection completed: ${name}"
            else
                failures=$((failures + 1))
                warn "Collection failed: ${name}"
            fi
        else
            if push_to_host "${name}"; then
                successes=$((successes + 1))
                log "Push completed: ${name}"
            else
                failures=$((failures + 1))
                warn "Push failed: ${name}"
            fi
        fi
    done

    printf '\n' >&2
    log "Successful hosts: ${successes}"
    log "Failed hosts: ${failures}"

    if [[ "${MODE}" == "collect" && "${failures}" == "0" ]]; then
        log "Collection finished. Run ${PROGRAM} DIRECTORY afterward to distribute the collected winners to every host."
    fi

    ((failures == 0))
}

parse_arguments "$@"

[[ -f "${CONFIG_FILE}" ]] || die "Configuration file not found: ${CONFIG_FILE}"

# Source at script scope. This preserves `declare -A RSYNC_HOSTS` as a global array.
# shellcheck disable=SC1090
source "${CONFIG_FILE}"

set_config_defaults
run
