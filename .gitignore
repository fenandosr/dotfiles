# Ignore everything
/*
# Ignore all files and folders recursively
/**

# But not these files...

## cookiecutters
!/.cookiecutterrc

## bash and zsh
!/.bashrc
!/.bash_aliases
!/.zshrc

## fragment loaders (composed by os-*/shell-*/profile-* branches)
!/.shell.d/
!/.shell.d/**
!/.zsh.d/
!/.zsh.d/**

## zsh plugins (submodules, profile-full branch only)
!/.gitmodules
!/.zsh/
!/.zsh/zsh-files/
!/.zsh/zsh-autosuggestions/
!/.zsh/zsh-syntax-highlighting/
!/.zsh/zsh-z/
!/.zsh/zsh-completions/

## host bootstrap manifests (os-*/profile-* branches)
!/.dotfiles/
!/.dotfiles/**

## git
!/.gitconfig
!/.gitignore

## docs
!/README.md
!/INSTALL_UBUNTU.md

## vim
!/.vimrc

## tmux
!/.tmux.conf

## config
!/.config/
!/.config/direnv/
!/.config/direnv/**
!/.config/ranger/
!/.config/ranger/**
!/.config/wtf/
!/.config/wtf/**
.config/wtf/log.txt

!/.config/alacritty/
!/.config/alacritty/**
.config/alacritty/theme.toml

## bin
!/bin/
!/bin/**

## local bin (scripts de usuario)
!/.local/
!/.local/bin/
!/.local/bin/**
.local/bin/claude
.local/bin/micromamba
.local/bin/uv
.local/bin/uvx
.local/bin/wtfutil

## systemd user services
!/.config/systemd/
!/.config/systemd/user/
!/.config/systemd/user/*.service

## bootstrap
!/install.sh

