#!/usr/bin/env bash
set -euo pipefail

ENV_NAME="jn-genomics"

find_jupyter() {
  local base
  for base in "$HOME/micromamba" "$HOME/mambaforge" "$HOME/miniforge3" "$HOME/miniconda3" "$HOME/anaconda3" \
              "$HOME/opt/miniconda3" "$HOME/opt/anaconda3" "/opt/homebrew/Caskroom/miniforge/base"; do
    local bin="$base/envs/$ENV_NAME/bin/jupyter"
    [[ -x "$bin" ]] && echo "$bin" && return
  done
  return 1
}

JUPYTER=$(find_jupyter 2>/dev/null) || {
  echo "No se encontró el env conda '$ENV_NAME'." >&2
  echo "Créalo con:" >&2
  echo "  micromamba env create -f ~/repos/condas/jn-genomics.yml" >&2
  exit 1
}

exec "$JUPYTER" notebook "$@"
