[user]
    email = fenandos@bit-a-bit.org
    name = Fernando Rivas

[core]
    autocrlf = input
    excludesfile = ~/.gitignore_global

[pull]
    rebase = false

[init]
    defaultBranch = main

[alias]
    st  = status -sb
    lg  = log --oneline --graph --decorate --all
    co  = checkout
    br  = branch
    undo = reset HEAD~1 --mixed
