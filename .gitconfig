[user]
    name = Fernando Rivas
    # email goes in ~/.gitconfig.local

[core]
    autocrlf = input
    editor = vim
    excludesfile = ~/.gitignore_global
    pager = delta

[interactive]
    diffFilter = delta --color-only

[delta]
    navigate = true
    side-by-side = true
    line-numbers = true

[merge]
    conflictstyle = diff3

[diff]
    colorMoved = default

[pull]
    rebase = false

[init]
    defaultBranch = main

[include]
    path = ~/.gitconfig.local

[alias]
    st  = status -sb
    lg  = log --oneline --graph --decorate --all
    co  = checkout
    br  = branch
    undo = reset HEAD~1 --mixed
